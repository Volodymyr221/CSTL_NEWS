{
  "permissions": {
    "allow": [
      "mcp__supabase",
      "mcp__supabase__*",
      "mcp__5c20a406-7f30-4b2c-8326-9c11ad1589ac",
      "mcp__5c20a406-7f30-4b2c-8326-9c11ad1589ac__*",
      "Bash(node*)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git add*)",
      "Bash(git commit*)",
      "Bash(git push*)",
      "Bash(git fetch*)",
      "Bash(git pull*)",
      "Bash(git branch*)",
      "Bash(git checkout*)",
      "Bash(date*)",
      "Bash(wc*)",
      "Bash(ls*)",
      "Bash(mkdir*)",
      "Bash(cat*)",
      "Bash(echo*)"
    ],
    "deny": [
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git reset --hard*)",
      "Bash(rm -rf*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "bash /home/user/CSTL_NEWS/.claude/hooks/session-git-sync.sh"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/home/user/CSTL_NEWS/.claude/hooks/context-warning.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node /home/user/CSTL_NEWS/.claude/hooks/pre-edit-read-check.js"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node /home/user/CSTL_NEWS/.claude/hooks/byyou-push-lock.js"
          }
        ]
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node /home/user/CSTL_NEWS/.claude/hooks/token-guard.js pre"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Agent|Task",
        "hooks": [
          {
            "type": "command",
            "command": "node /home/user/CSTL_NEWS/.claude/hooks/token-guard.js post"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "file=\"$CLAUDE_TOOL_INPUT_FILE_PATH\"; if [[ \"$file\" == *.js ]]; then node --check \"$file\" && echo \"✓ синтаксис OK: $file\" || echo \"✗ ПОМИЛКА синтаксису: $file\"; fi"
          },
          {
            "type": "command",
            "command": "bash /home/user/CSTL_NEWS/.claude/hooks/cache-name-reminder.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash /home/user/CSTL_NEWS/.claude/hooks/byyou-context-guard.sh"
          }
        ]
      }
    ]
  }
}
